# pyenv
.python-version

# pipenv
#   According to pypa/pipenv#1181, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or even
#   fail to install.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#pdm.lock
#   pdm uses .pdm-python to store the python path, which is platform-specific.
.pdm-python
#   pdm stores project-wide configurations in .pdm.toml, which is local-only.
.pdm.toml

# PEP 582; used by e.g. github.com/pypa/pdm
__pypackages__/

